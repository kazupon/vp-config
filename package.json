{
  "name": "@kazupon/vp-config",
  "version": "0.1.0",
  "description": "Vite Plus configuration for @kazupon",
  "homepage": "https://github.com/kazupon/vp-config#readme",
  "bugs": {
    "url": "https://github.com/kazupon/vp-config/issues"
  },
  "license": "MIT",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazupon/vp-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "docs": "typedoc --excludeInternal",
    "dev": "vp pack --watch",
    "test": "vp test",
    "changelog": "gh-changelogen --repo=kazupon/vp-config",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "pnpm run build",
    "prepack": "vp pack",
    "knip": "knip",
    "release": "bumpp --commit \"release: v%s\" --all --push --tag",
    "prepare": "vp config"
  },
  "dependencies": {
    "@kazupon/eslint-plugin": "^0.7.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "gh-changelogen": "^0.2.8",
    "knip": "^5.86.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "inlinedDependencies": {
    "@oxc-project/types": "0.115.0",
    "@types/chai": "5.2.3",
    "@types/deep-eql": "4.0.2",
    "@voidzero-dev/vite-plus-core": "0.1.12",
    "@voidzero-dev/vite-plus-test": "0.1.12",
    "assertion-error": "2.0.1",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "postcss": "8.5.8",
    "vite-plus": "0.1.12"
  }
}
